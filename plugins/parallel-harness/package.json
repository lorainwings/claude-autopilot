{
  "name": "parallel-harness",
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "test": "bun test tests/unit/ && bun test tests/integration/",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "typecheck": "bunx tsc --noEmit",
    "build": "bash tools/build-dist.sh"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "typescript": "5.9.3"
  }
}
