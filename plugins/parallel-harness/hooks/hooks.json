{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Skill$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/runtime/scripts/record-skill-tool-event.sh PreToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Skill$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/runtime/scripts/record-skill-tool-event.sh PostToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "^Skill$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/runtime/scripts/record-skill-tool-event.sh PostToolUseFailure",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/runtime/scripts/auto-install-statusline.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
