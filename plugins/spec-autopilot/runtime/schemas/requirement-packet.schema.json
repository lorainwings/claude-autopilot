{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase1 Requirement Packet",
  "description": "Structured requirement packet produced by PackagerAgent in Phase 1 Step 1.9.3. Consumed read-only by the main thread and all downstream phases; MUST NOT be hand-authored by the orchestrator.",
  "type": "object",
  "required": [
    "goal",
    "scope",
    "non_goals",
    "acceptance_criteria",
    "risks",
    "decisions",
    "needs_clarification",
    "sha256"
  ],
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 3,
      "description": "1-3 sentence business goal."
    },
    "scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "testable"],
        "properties": {
          "text": { "type": "string", "minLength": 3 },
          "testable": { "type": "boolean" },
          "source_ref": { "type": "string" }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "severity"],
        "properties": {
          "category": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "choice"],
        "properties": {
          "topic": { "type": "string" },
          "choice": { "type": "string" },
          "rationale": { "type": "string" },
          "options": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "needs_clarification": {
      "type": "array",
      "description": "Residual unresolved questions. Empty array means all questions closed before packet emission.",
      "items": {
        "type": "string",
        "pattern": "^\\[NEEDS CLARIFICATION:"
      }
    },
    "sha256": {
      "type": "string",
      "description": "sha256 hex digest of the canonicalized packet (computed with the sha256 field itself blanked).",
      "pattern": "^[0-9a-f]{64}$"
    },
    "goal_source_ref": { "type": "string" },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requirement_type": {
      "type": "string",
      "enum": ["feature", "bugfix", "refactor", "chore"]
    },
    "requirement_maturity": {
      "type": "string",
      "enum": ["clear", "partial", "ambiguous", "mature"]
    },
    "complexity": {
      "type": "string",
      "enum": ["small", "medium", "large"]
    },
    "version": { "type": "string" },
    "timestamp": { "type": "string" }
  }
}
