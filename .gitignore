openspec/*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
build/
# 注意：.mypy_cache/ .ruff_cache/ .pytest_cache/ 等已通过 --cache-dir / pyproject 配置
# 重定向到 .cache/ 统一目录（见底部 .cache/）；保留下列规则作为兜底，防御部分工具
# 在用户本地仍生成根目录缓存（如直接执行 mypy/ruff 不带配置时）
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
ENV/
env/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Build outputs (except dist/<plugin-name> which is tracked for marketplace install)
!dist/spec-autopilot/
dist/spec-autopilot/assets/gui/.build-meta.json
plugins/spec-autopilot/gui-dist/
build/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# Temporary files
tmp/
temp/
*.tmp
plugins/spec-autopilot/logs/
.tmp-review-*/

# Development tools (downloaded by make setup)
.tools/

# Worktrees
.worktrees/
.parallel-harness

# parallel-harness 动态构建产物（由 tools/build-dist.sh 生成）
plugins/parallel-harness/BUILD_MANIFEST.json
# dist/parallel-harness/ 是插件市场产物，与 dist/spec-autopilot/ 一样需要跟踪
!dist/parallel-harness/
!dist/daily-report/

# spec-autopilot 运行时临时产物（候选清单、聚合报告、patch、mutation/health 报告）
.cache/
