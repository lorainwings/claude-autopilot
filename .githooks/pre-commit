#!/usr/bin/env bash
# pre-commit hook: run spec-autopilot test suite and doc sync check

set -uo pipefail

# Cross-platform in-place sed (BSD vs GNU)
sedi() {
  if sed --version 2>/dev/null | grep -q GNU; then
    sed -i "$@"
  else
    sed -i '' "$@"
  fi
}

# ============================================
# Part 1: Hook Test Suite
# ============================================

# Check if any plugin files are staged (all types, not just sh/json)
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^plugins/' || true)

if [ -n "$STAGED" ]; then
  echo "🧪 Plugin files changed — running full build + test suite..."

  TEST_SCRIPT="plugins/spec-autopilot/tests/run_all.sh"

  if [ ! -f "$TEST_SCRIPT" ]; then
    echo "WARNING: tests/run_all.sh not found, skipping" >&2
  else
    if ! bash "$TEST_SCRIPT"; then
      echo ""
      echo "❌ Hook tests failed. Fix the issues above before committing."
      exit 1
    fi
    echo "✅ All hook tests passed."
  fi

  # ============================================
  # Part 1.5: Targeted Test Coverage Check
  # ============================================
  # Verify that modified scripts have corresponding test file changes
  CHANGED_SCRIPTS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^plugins/spec-autopilot/scripts/[^/]+\.sh$' | grep -v '_common\.sh' || true)
  TESTS_DIR="plugins/spec-autopilot/tests"
  TEST_FILES_DIFF=$(git diff --cached --name-only -- "$TESTS_DIR" 2>/dev/null || true)

  if [ -n "$CHANGED_SCRIPTS" ]; then
    MISSING_TESTS=""
    for script in $CHANGED_SCRIPTS; do
      script_basename=$(basename "$script" .sh)
      # Check if any test file in tests/ dir was also modified
      if [ -n "$TEST_FILES_DIFF" ]; then
        if ! echo "$TEST_FILES_DIFF" | grep -q "test_.*${script_basename}"; then
          MISSING_TESTS="${MISSING_TESTS}  - ${script_basename}.sh\n"
        fi
      else
        MISSING_TESTS="${MISSING_TESTS}  - ${script_basename}.sh\n"
      fi
    done

    if [ -n "$MISSING_TESTS" ]; then
      echo ""
      echo "⚠️  Scripts modified without corresponding test updates in tests/:"
      printf "$MISSING_TESTS"
      echo "   Each script change should include targeted test cases."
      echo ""
    fi
  fi

  echo ""
fi

# ============================================
# Part 2: Documentation Sync Check
# ============================================

# Check if any plugin code is staged
PLUGIN_CHANGED=$(git diff --cached --name-only | grep -q "plugins/spec-autopilot/" && echo "yes" || echo "no")

if [ "$PLUGIN_CHANGED" = "yes" ]; then
  echo "📚 Checking documentation sync..."
  echo ""

  # 0. Version management (plugin.json + README.md + marketplace.json)
  #    - Manual bump: propagate plugin.json version to other files
  #    - No bump: auto-increment patch version across all files
  PLUGIN_JSON="plugins/spec-autopilot/.claude-plugin/plugin.json"
  README_MD="plugins/spec-autopilot/README.md"
  MARKETPLACE_JSON=".claude-plugin/marketplace.json"
  CURRENT_VERSION=$(grep '"version"' "$PLUGIN_JSON" 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)

  if [ -n "$CURRENT_VERSION" ]; then
    if git diff --cached -- "$PLUGIN_JSON" | grep -q '"version"'; then
      # Manual bump detected — propagate to README.md + marketplace.json
      sedi "s/version-[0-9]\+\.[0-9]\+\.[0-9]\+-blue/version-${CURRENT_VERSION}-blue/" "$README_MD"
      sedi "s/\"version\": \"[0-9]\+\.[0-9]\+\.[0-9]\+\"/\"version\": \"${CURRENT_VERSION}\"/" "$MARKETPLACE_JSON"
      git add "$README_MD" "$MARKETPLACE_JSON"
      echo "🔖 Manual bump detected — synced all files to ${CURRENT_VERSION}"
    else
      # Auto-bump patch: X.Y.Z → X.Y.(Z+1)
      MAJOR=$(echo "$CURRENT_VERSION" | cut -d. -f1)
      MINOR=$(echo "$CURRENT_VERSION" | cut -d. -f2)
      PATCH=$(echo "$CURRENT_VERSION" | cut -d. -f3)
      NEW_PATCH=$((PATCH + 1))
      NEW_VERSION="${MAJOR}.${MINOR}.${NEW_PATCH}"

      sedi "s/\"version\": \"${CURRENT_VERSION}\"/\"version\": \"${NEW_VERSION}\"/" "$PLUGIN_JSON"
      sedi "s/version-${CURRENT_VERSION}-blue/version-${NEW_VERSION}-blue/" "$README_MD"
      sedi "s/\"version\": \"${CURRENT_VERSION}\"/\"version\": \"${NEW_VERSION}\"/" "$MARKETPLACE_JSON"

      git add "$PLUGIN_JSON" "$README_MD" "$MARKETPLACE_JSON"
      echo "🔖 Auto-bumped version: ${CURRENT_VERSION} → ${NEW_VERSION}"
    fi
  fi

  # 1. Check CHANGELOG.md is updated
  if ! git diff --cached --name-only | grep -q "CHANGELOG.md"; then
    echo "❌ Error: Plugin code modified but CHANGELOG.md not updated"
    echo ""
    echo "Please update CHANGELOG.md with your changes:"
    echo "  1. Add new version section at the top"
    echo "  2. Document Added/Changed/Fixed items"
    echo "  3. git add CHANGELOG.md"
    echo ""
    exit 1
  fi

  # 2. Check version consistency (plugin.json vs README.md vs marketplace.json)
  PLUGIN_VERSION=$(grep '"version"' plugins/spec-autopilot/.claude-plugin/plugin.json 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
  README_VERSION=$(grep 'version-' plugins/spec-autopilot/README.md 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
  MARKETPLACE_VERSION=$(grep '"version"' .claude-plugin/marketplace.json 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)

  if [ -n "$PLUGIN_VERSION" ]; then
    VERSION_MISMATCH=""
    if [ -n "$README_VERSION" ] && [ "$PLUGIN_VERSION" != "$README_VERSION" ]; then
      VERSION_MISMATCH="${VERSION_MISMATCH}  README.md:        $README_VERSION\n"
    fi
    if [ -n "$MARKETPLACE_VERSION" ] && [ "$PLUGIN_VERSION" != "$MARKETPLACE_VERSION" ]; then
      VERSION_MISMATCH="${VERSION_MISMATCH}  marketplace.json: $MARKETPLACE_VERSION\n"
    fi

    if [ -n "$VERSION_MISMATCH" ]; then
      echo "❌ Error: Version mismatch"
      echo "  plugin.json:    $PLUGIN_VERSION"
      printf "$VERSION_MISMATCH"
      echo ""
      exit 1
    fi
    echo "✅ Version consistent: $PLUGIN_VERSION"
  fi

  # 3. Warn if Hook scripts changed but docs not updated
  if git diff --cached --name-only | grep -q "plugins/spec-autopilot/scripts/.*\.sh"; then
    if ! git diff --cached --name-only | grep -q "plugins/spec-autopilot/README.md\|plugins/spec-autopilot/docs/"; then
      echo "⚠️  Warning: Hook scripts modified but docs not updated"
      echo "   Consider updating: README.md, docs/architecture.md, docs/gates.md"
      echo ""
    fi
  fi

  # 4. Warn if Skills changed but README not updated
  if git diff --cached --name-only | grep -q "plugins/spec-autopilot/skills/.*/SKILL\.md"; then
    if ! git diff --cached --name-only | grep -q "plugins/spec-autopilot/README.md"; then
      echo "⚠️  Warning: Skill files modified but README.md not updated"
      echo "   Consider updating: README.md (Skills table)"
      echo ""
    fi
  fi

  # ============================================
  # Part 2.5: Rebuild dist (AFTER version bump)
  # ============================================
  echo "📦 Rebuilding dist/plugin/..."
  if bash plugins/spec-autopilot/scripts/build-dist.sh; then
    git add dist/spec-autopilot/
  else
    echo "❌ dist build failed. Fix the build before committing."
    exit 1
  fi

  echo "✅ Documentation sync check passed"
  echo ""
fi

exit 0
