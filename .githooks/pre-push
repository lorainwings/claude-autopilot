#!/usr/bin/env bash
# pre-push hook: 推送前最终防线（分钟级兜底）
#
# 本 Hook 遵循社区最佳实践分层：
#   pre-commit：秒级反馈（格式化、增量 lint、版本一致性）
#   pre-push ：分钟级兜底（typecheck + dist freshness + 分支同步 + 受影响 plugin 增量测试）
#   CI        ：全量矩阵（完整测试、多 OS、release discipline）
#
# 设计取舍：
#   - typecheck 在本地执行：tsc/mypy 失败 5–15s 内定位，比等 CI 更快
#   - 受影响 plugin 测试在本地执行：本地 OS 原生捕获 OS 专属 bug（macOS / Linux），
#     消除"PR CI 某 OS 不覆盖 → OS 专属 bug 漏到 main"的真空窗口
#   - 紧急绕过：AUTOPILOT_SKIP_TEST=1 git push ...（仅在极端场景使用）

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# ── release-please branch bypass ──
_CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$_CURRENT_BRANCH" == release-please--* ]]; then
  exit 0
fi

# ── 0. 分支必须与 origin/main 同步（规范化提交流程闸口）──
if ! bash "$REPO_ROOT/scripts/check-branch-synced.sh"; then
  exit 1
fi

# ── 1. dist 内容一致性 (对比已提交状态，排除工作树 WIP 干扰) ──
echo "🔍 Pre-push: checking dist freshness..."

_needs_stash=false
if ! git diff --quiet 2>/dev/null \
   || ! git diff --cached --quiet 2>/dev/null \
   || [ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ]; then
  _needs_stash=true
  git stash push -q --include-untracked -m "pre-push-freshness-check" 2>/dev/null
fi

_freshness_ok=true
if ! bash "$REPO_ROOT/scripts/check-dist-freshness.sh" all; then
  _freshness_ok=false
fi

if [ "$_needs_stash" = "true" ]; then
  git stash pop -q 2>/dev/null || true
fi

if [ "$_freshness_ok" = "false" ]; then
  echo ""
  echo "❌ dist is stale. Please rebuild and commit:"
  echo "   make build && git add dist/spec-autopilot/"
  echo "   make ph-build-only && git add dist/parallel-harness/"
  echo "   make dr-build && git add dist/daily-report/"
  echo "   git commit -m 'chore: rebuild dist'"
  echo ""
  echo "   Or rebuild all: make build ph-build-only dr-build && git add dist/ && git commit -m 'chore: rebuild dist'"
  exit 1
fi

# ── 2. dist 变更是否已提交 (防止 build 了但没 commit) ──
UNCOMMITTED=0
for plugin in spec-autopilot parallel-harness daily-report; do
  if [ -d "dist/$plugin" ]; then
    if ! git diff --quiet -- "dist/$plugin" 2>/dev/null; then
      echo "❌ dist/$plugin has unstaged changes"
      UNCOMMITTED=1
    fi
    if ! git diff --cached --quiet -- "dist/$plugin" 2>/dev/null; then
      echo "❌ dist/$plugin has staged but uncommitted changes"
      UNCOMMITTED=1
    fi
    _untracked=$(git ls-files --others --exclude-standard "dist/$plugin")
    if [ -n "$_untracked" ]; then
      echo "❌ dist/$plugin has untracked files"
      UNCOMMITTED=1
    fi
  fi
done

if [ "$UNCOMMITTED" -eq 1 ]; then
  echo ""
  echo "❌ dist/ has uncommitted changes. Stage and commit before pushing."
  exit 1
fi

# ── 3. TypeScript / Python 类型检查（5–15s，CI 之前的本地兜底） ──
# 设计：完整测试由 CI 跑，但类型错误在本地暴露代价极低且诊断更快。
echo "🔍 Pre-push: typecheck (spec-autopilot + parallel-harness)..."
if ! make typecheck >/dev/null; then
  echo "❌ spec-autopilot typecheck failed. Run 'make typecheck' for details."
  exit 1
fi
if ! make ph-typecheck >/dev/null; then
  echo "❌ parallel-harness typecheck failed. Run 'make ph-typecheck' for details."
  exit 1
fi

# ── 4. 受影响 plugin 增量测试（本地 OS 原生，消除 OS 真空） ──
# 仅在 runtime/ 或 tests/ 有改动时触发，避免纯文档 push 被拖慢。
# 对比 upstream（@{u}）→ merge-base，精准定位本次 push 引入的改动。
# AUTOPILOT_SKIP_TEST=1 可紧急绕过（hotfix / 明知不影响测试的场景）。
if [ "${AUTOPILOT_SKIP_TEST:-}" != "1" ]; then
  _UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "origin/main")
  _DIFF_BASE=$(git merge-base HEAD "$_UPSTREAM" 2>/dev/null || git rev-parse origin/main 2>/dev/null || echo "HEAD~1")
  _AFFECTED_PLUGINS=$(git diff --name-only "$_DIFF_BASE" HEAD 2>/dev/null \
    | grep -E '^plugins/(spec-autopilot|parallel-harness)/(runtime|tests)/' \
    | awk -F/ '{print $2}' | sort -u)

  if [ -n "$_AFFECTED_PLUGINS" ]; then
    echo "🧪 Pre-push: running affected plugin tests on $(uname -s)..."
    for plugin in $_AFFECTED_PLUGINS; do
      case "$plugin" in
        spec-autopilot)
          echo "  → spec-autopilot test suite (make test)"
          if ! make test >/dev/null 2>&1; then
            echo ""
            echo "❌ spec-autopilot tests failed on $(uname -s)."
            echo "   Run 'make test' for details, or AUTOPILOT_SKIP_TEST=1 git push ... (emergency only)"
            exit 1
          fi
          ;;
        parallel-harness)
          echo "  → parallel-harness test suite (make ph-test)"
          if ! make ph-test >/dev/null 2>&1; then
            echo ""
            echo "❌ parallel-harness tests failed on $(uname -s)."
            echo "   Run 'make ph-test' for details, or AUTOPILOT_SKIP_TEST=1 git push ... (emergency only)"
            exit 1
          fi
          ;;
      esac
    done
  fi
fi

echo "✅ Pre-push checks passed"
